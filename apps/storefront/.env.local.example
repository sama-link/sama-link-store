# ============================================================
# SAMA LINK STOREFRONT — local development env
# ============================================================
# Copy this file to apps/storefront/.env.local, then fill in the
# two ID values from the seed output:
#
#   docker compose -f docker-compose.dev.yml exec backend \
#     sh -c "cd /app/apps/backend && npm run seed:local"
#
# The seed prints a "Local development summary" block that ends
# with the exact lines to paste here.
#
# Only NEXT_PUBLIC_* values belong in this file — they are bundled
# into the client. Never put backend secrets (JWT_SECRET,
# COOKIE_SECRET, DATABASE_URL, Paymob keys, Bosta keys, Tepro keys)
# here. Governed integrations are Paymob (payments — ADR-048,
# supersedes the prior Stripe direction) and Bosta + Tepro
# (shipping — ADR-049). All of those are server-side only.
# ============================================================

NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Provisioned by `npm run seed:local` — copy from the printed summary.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_API_KEY=pk_REPLACE_WITH_SEED_OUTPUT
NEXT_PUBLIC_MEDUSA_REGION_ID=reg_REPLACE_WITH_SEED_OUTPUT

# Optional — footer social icons (omit a key to hide that icon)
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://facebook.com/your-page
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://instagram.com/your-profile
# NEXT_PUBLIC_SOCIAL_TWITTER_URL=https://x.com/your-profile
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://youtube.com/@your-channel
# NEXT_PUBLIC_SOCIAL_WHATSAPP_URL=https://wa.me/201000000000

# Optional — Contact page map iframe `src` (Google Maps embed HTML URL or OSM embed)
# NEXT_PUBLIC_CONTACT_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...
