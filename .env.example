# ============================================================
# SAMA LINK STORE — Environment Variable Reference
# ============================================================
# Copy this file to .env.local (storefront) or .env (backend)
# and fill in real values. NEVER commit .env files with secrets.
# ============================================================

# --- Node Environment ---
NODE_ENV=development

# --- Storefront (Next.js) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_API_KEY=  # Medusa v2 Store API key — provision via Medusa Admin after BACK-3 seed, required for BACK-5
# Egypt region ID — copy from seed output line: "[seed] Part A: ..."
# Required for EGP-denominated storefront pricing
NEXT_PUBLIC_MEDUSA_REGION_ID=<egypt-region-id-from-seed-output>

# --- Medusa Backend ---
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=supersecret
JWT_SECRET=your-jwt-secret-min-32-chars
COOKIE_SECRET=your-cookie-secret-min-32-chars
MEDUSA_ADMIN_ONBOARDING_TYPE=default
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:5173
AUTH_CORS=http://localhost:3000,http://localhost:9000

# --- Database (PostgreSQL) ---
# Docker Compose local dev (hostname = docker service name, not localhost):
#   DATABASE_URL=postgres://postgres:postgres@postgres:5432/sama_link_db?sslmode=disable
# Native PostgreSQL local dev:
DATABASE_URL=postgres://user:password@localhost:5432/sama_link_db
# PGSSLMODE=disable  # Set for local Docker — local Postgres container has no SSL enabled

# --- Redis (optional, for session/queue) ---
# REDIS_URL=redis://localhost:6379

# --- Payment: Stripe (Phase 4+) ---
# STRIPE_API_KEY=sk_test_REPLACE
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# --- Search: Meilisearch (Phase 7+) ---
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=REPLACE

# --- Email (Phase 5+) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@samalink.store

# --- Storage: S3-compatible (Phase 3+) ---
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=   # set for non-AWS providers (e.g. Cloudflare R2)

# --- Analytics (Phase 7+) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-REPLACE
# NEXT_PUBLIC_GTM_ID=GTM-REPLACE

# --- Admin (Phase 6+) ---
# MEDUSA_ADMIN_BACKEND_URL=http://localhost:9000

# ============================================================
# CLOUD RUN DEPLOYMENT (feature/cloud-run-deploy)
# These values are set as GitHub Actions secrets, NOT in this file.
# Documented here for reference only.
# ============================================================

# -- GCP / Artifact Registry --
# Project:  linear-reason-460715-n1
# Region:   us-east1
# Registry: us-east1-docker.pkg.dev/linear-reason-460715-n1/sama-link/
# Backend image:    .../backend:latest
# Storefront image: .../storefront:latest

# -- GitHub Actions secrets required (backend) --
# WIF_PROVIDER              Workload Identity Federation provider resource name
# WIF_SERVICE_ACCOUNT       GCP service account email used for deployment
# NEON_DATABASE_URL         Full Neon connection string (sslmode=require&channel_binding=require)
# JWT_SECRET                Min 32 chars — set once, never change
# COOKIE_SECRET             Min 32 chars — set once, never change
# MEDUSA_ADMIN_EMAIL        Initial admin user email
# MEDUSA_ADMIN_PASSWORD     Initial admin user password
# STORE_CORS                Storefront Cloud Run URL (update after storefront first deploys)
# ADMIN_CORS                Backend Cloud Run URL
# AUTH_CORS                 Storefront + backend URLs comma-separated

# -- GitHub Actions secrets required (storefront) --
# WIF_PROVIDER              (same as backend)
# WIF_SERVICE_ACCOUNT       (same as backend)
# NEXT_PUBLIC_MEDUSA_BACKEND_URL    Backend Cloud Run URL
# NEXT_PUBLIC_BASE_URL              Storefront Cloud Run URL
# NEXT_PUBLIC_DEFAULT_LOCALE        ar
# NEXT_PUBLIC_MEDUSA_PUBLISHABLE_API_KEY  From seed output — set before first storefront deploy
# NEXT_PUBLIC_MEDUSA_REGION_ID            From seed output — set before first storefront deploy
